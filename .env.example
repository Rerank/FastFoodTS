# Шаблон переменных окружения фронтенда.
# Только VITE_-переменные доступны в коде; они публичны (без секретов).

# Источник данных: mock — вшитые данные (без бэкенда и БД); иначе — HTTP-бэкенд
VITE_DATA_SOURCE=mock

# Базовый URL backend API (используется, когда VITE_DATA_SOURCE != mock)
VITE_API_BASE_URL=http://localhost:3000/api
